# LLM API 配置
# 支持的提供商: claude, zhipu, deepseek, qianwen
LLM_PROVIDER=claude
# LLM_MODEL=claude-sonnet-4-6  # 可选，不配置则使用默认模型

# Claude API 配置
# 获取 API Key: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-claude-api-key-here
# Claude API 中转站地址（可选，使用官方 API 则不需要设置）
# ANTHROPIC_BASE_URL=https://your-proxy-url.com

# 智谱 AI API 配置
# 获取 API Key: https://open.bigmodel.cn/
ZHIPUAI_API_KEY=your-zhipu-api-key-here

# DeepSeek API 配置
# 获取 API Key: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# 通义千问 API 配置
# 获取 API Key: https://dashscope.console.aliyun.com/
QIANWEN_API_KEY=your-qianwen-api-key-here

# TTS 配置（可选）
TTS_VOICE=zh-CN-XiaoxiaoNeural
TTS_RATE=+0%
TTS_PITCH=+0Hz
